# 应用基础信息
APP_NAME=axum-service-scaffold
APP_ENV=development

# Web 服务监听配置
SERVER_HOST=127.0.0.1
SERVER_PORT=8080

# SeaORM 数据库连接配置
DATABASE_URL=sqlite://scaffold.db?mode=rwc
DATABASE_MAX_CONNECTIONS=10
DATABASE_MIN_CONNECTIONS=1
DATABASE_CONNECT_TIMEOUT_SECS=8
DATABASE_SQLX_LOGGING=false

# JWT 配置
JWT_SECRET=change-me-to-a-random-string-with-at-least-32-characters
JWT_ISSUER=axum-service-scaffold
JWT_AUDIENCE=axum-service-clients
JWT_ACCESS_TOKEN_TTL_MINUTES=120

# 日志过滤规则
LOG_FILTER=info,tower_http=info
